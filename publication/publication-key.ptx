<?xml version="1.0" encoding="UTF-8"?>
<!--
	publication-key.ptx
	Instructor key: blanks visible AND solutions/answers shown inline.

	Same source tree as the student build; the differences are that
	(1) <task-default>, <solutions-divisional>, and <solutions-worksheet>
	here list every part of an exercise, so the <solution> bodies appear,
	and (2) <version include> below lists the "key" component but not
	"stu" — per the shared worksheet conventions
	(checklists/worksheet-conventions.md), component="key" elements
	(answer paragraphs, exercises with solutions) appear in this build
	only.  "instructor" is also kept in the list for any legacy
	component="instructor" content (the legacy worksheets' <commentary>
	blocks are currently commented out in the source); drop it once Task
	M6 migrates them.  The old `commentary` stringparam is deprecated and
	non-functional in PreTeXt 2.43.1; component + version support is the
	working mechanism.
-->
<publication>
	<source>
		<directories external="notes/assets" generated="notes/generated-assets" />
		<version include="web readings emoji example-solution instructor key" />
	</source>

	<common>
		<!-- Level at which are html files generated (chapter/section/etc) -->
		<chunking level="3" />
		<!-- Depth for table of contents.  0 means no TOC -->
		<tableofcontents level="3" />
		<!-- Visibility of exercise components where they first appear -->
		<exercise-inline statement="yes" hint="yes" answer="no" solution="yes" />
		<exercise-divisional statement="yes" hint="yes" answer="no" solution="yes" />
		<exercise-worksheet statement="yes" hint="yes" answer="no" solution="yes" />
		<exercise-reading statement="yes" hint="yes" answer="no" solution="yes" />
		<exercise-project statement="yes" hint="yes" answer="yes" solution="yes" />
		<!-- Style of fill-in-the-blanks -->
		<fillin textstyle="underline" mathstyle="shade" />
		<!-- You can set a watermark -->
		<!-- <watermark scale="0.5">DRAFT</watermark> -->
		<!-- Mermaid diagram themes -->
		<!-- <mermaid theme="default" /> -->
		<!-- QR code image: set path to an image to put in center of QR codes -->
		<!-- <qrcode image="image.png" /> -->
		<tabular top="major" bottom="minor"/>

		<task-default>
			<statement/>
			<hint/>
			<answer/>
			<solution/>
		</task-default>

		<solutions-divisional>
			<statement/>
			<hint/>
			<answer/>
			<solution/>
		</solutions-divisional>
		<solutions-worksheet>
			<statement/>
			<hint/>
			<answer/>
			<solution/>
		</solutions-worksheet>
	</common>
	
	<numbering/>

</publication>
