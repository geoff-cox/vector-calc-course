<?xml version="1.0" encoding="UTF-8"?>
<!--
	sec-functions-vectors.ptx
	Section 1: Functions, Vectors, and Vector Fields.

	A section is a container; each class meeting gets its own
	<worksheet> file, which we pull in with <xi:include/>.  This
	keeps individual worksheets small enough to edit comfortably
	and lets you re-order class meetings by re-ordering includes.
-->
<section xml:id="sec-functions-vectors"
		 xmlns:xi="http://www.w3.org/2001/XInclude">

	<title>Functions, Vectors, and Vector Fields</title>

	<introduction>
		<p>
			We open the course by reviewing the function notation you
			already know from Calculus 1&#8211;3 and then expanding it
			to handle the multivariable, vector-valued objects that
			this course is really about.  By the end of the section
			we'll be comfortable with scalar functions of two and
			three variables, vector-valued functions, and the algebra
			and geometry of vectors in <m>\R^2</m> and <m>\R^3</m>.
		</p>
	</introduction>

	<!-- Class meeting 1: Review of multivariable function notation -->
	<xi:include href="./ws-function-notation.ptx"/>

	<!-- Class meeting 2: Vectors -->
	<xi:include href="./ws-vectors.ptx"/>

	<!-- Class meeting 3: The dot product -->
	<xi:include href="./ws-dot-product.ptx"/>

	<!-- Class meeting 4: The cross product -->
	<xi:include href="./ws-cross-product.ptx"/>

	<!-- Future worksheets in this section (uncomment as you write them): -->
