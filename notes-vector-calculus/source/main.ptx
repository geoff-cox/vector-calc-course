<?xml version="1.0" encoding="UTF-8"?>

<!--
	main.ptx
	Root source file for the lecture notes.

	The overall structure mirrors the existing course:

		Ch 1  Functions, Vectors, and Vector Fields
		Ch 2  Line Integrals and Green's Theorem
		Ch 3  Surface Integrals, Stokes' Theorem, and the Divergence Theorem

	Each chapter contains one <worksheet> per class meeting (rather
	than one <section> per topic), which matches the "guided notes"
	style the course already uses.

	New chapters/worksheets are added by:
		1. dropping a new file in source/,
		2. adding an <xi:include/> below.
-->
<pretext xmlns:xi="http://www.w3.org/2001/XInclude">

	<docinfo>
		<macros>
			\newcommand{\R}{\mathbb{R}}
			\newcommand{\vF}{\mathbf{F}}
			\newcommand{\vG}{\mathbf{G}}
			\newcommand{\va}{\mathbf{a}}
			\newcommand{\vb}{\mathbf{b}}
			\newcommand{\vc}{\mathbf{c}}
			\newcommand{\vu}{\mathbf{u}}
			\newcommand{\vv}{\mathbf{v}}
			\newcommand{\vw}{\mathbf{w}}
			\newcommand{\vr}{\mathbf{r}}
			\newcommand{\vn}{\mathbf{n}}
			\newcommand{\vi}{\mathbf{i}}
			\newcommand{\vj}{\mathbf{j}}
			\newcommand{\vk}{\mathbf{k}}
			\newcommand{\vzero}{\mathbf{0}}
			\newcommand{\norm}[1]{\left\lvert #1 \right\rvert}
			\DeclareMathOperator{\dom}{dom}
			\DeclareMathOperator{\range}{range}
			\DeclareMathOperator{\proj}{proj}
			\DeclareMathOperator{\comp}{comp}
		</macros>
	</docinfo>

	<book xml:id="vector-calc-notes">
		<title>Vector Calculus</title>
		<subtitle>Guided Lecture Notes</subtitle>

		<frontmatter xml:id="frontmatter">
			<bibinfo>

				<author>
					<personname>Geoffrey W. Cox, Ph.D.</personname>
					<department>Applied Mathematics</department>
					<institution>Virginia Military Institute</institution>
					<email>coxgeoff@vmi.edu</email>
				</author>

				<date><today /></date>

				<edition>1st Edition</edition>

				<website>
					<url href="https://vmi-math.com">https://vmi-math.com</url>
				</website>

				<copyright>
					<year>2025<ndash />2026</year>
					<holder>Geoffrey W. Cox, Ph.D.</holder>
					<!-- <minilicense>CC BY-SA 4.0</minilicense> -->
