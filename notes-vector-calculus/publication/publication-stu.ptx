<?xml version="1.0" encoding="UTF-8"?>
<!--
    publication-stu.ptx
    Student handout: blanks visible, but solutions and answers suppressed.

    Same source tree as the instructor key (publication-key.ptx); the only
    difference is that here <task-default>, <solutions-divisional>, and
    <solutions-worksheet> emit only the <statement/>, and the <exercise-*>
    visibility flags set solution="no" / answer="no", so the <solution>
    bodies are dropped from this build.  The <fillin/> blanks still render
    (students write in them during class).
-->
<publication>
	<source>
		<directories external="../assets" generated="../generated-assets" />
		<version include="web readings emoji example-solution" />
	</source>

	<common>
		<!-- Level at which are html files generated (chapter/section/etc) -->
		<chunking level="3" />
		<!-- Depth for table of contents.  0 means no TOC -->
		<tableofcontents level="3" />
		<!-- Visibility of exercise components where they first appear -->
		<exercise-inline statement="yes" hint="yes" answer="no" solution="no" />
		<exercise-divisional statement="yes" hint="yes" answer="no" solution="no" />
		<exercise-worksheet statement="yes" hint="yes" answer="no" solution="no" />
		<exercise-reading statement="yes" hint="yes" answer="no" solution="no" />
		<exercise-project statement="yes" hint="yes" answer="no" solution="no" />
		<!-- Style of fill-in-the-blanks -->
		<fillin textstyle="underline" mathstyle="shade" />
        <tabular top="major" bottom="minor"/>

        <task-default>
            <statement/>
            <hint/>
        </task-default>

        <solutions-divisional>
            <statement/>
        </solutions-divisional>
        <solutions-worksheet>
            <statement/>
        </solutions-worksheet>
	</common>
    
    <numbering/>

</publication>
